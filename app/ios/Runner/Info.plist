<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>voip</string>
	</array>
	<key>NSMicrophoneUsageDescription</key>
	<string>Nakama Sync requires microphone access for Link.</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Nakama Sync uses Bluetooth to discover and connect nearby Link peers.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Nakama Sync uses the local network to discover and communicate with nearby Link peers.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_5A731AB9F7B8._tcp</string>
		<string>_5a731ab9f7b8._tcp</string>
		<string>_5a731ab9f7b8e1270c87378d._tcp</string>
	</array>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Nakama Sync uses location access only to support nearby peer discovery.</string>
	<key>UIRequiresPersistentWiFi</key>
	<true/>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Nakama Sync</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
